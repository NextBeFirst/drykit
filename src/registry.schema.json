{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "claudestarter registry",
  "type": "object",
  "required": ["version", "components", "hooks", "utils"],
  "properties": {
    "version": { "type": "string", "const": "1" },
    "generatedAt": { "type": ["string", "null"], "format": "date-time" },
    "components": {
      "type": "array",
      "items": { "$ref": "#/definitions/entry" }
    },
    "hooks": {
      "type": "array",
      "items": { "$ref": "#/definitions/entry" }
    },
    "utils": {
      "type": "array",
      "items": { "$ref": "#/definitions/entry" }
    }
  },
  "definitions": {
    "entry": {
      "type": "object",
      "required": ["name", "path", "dateCreated", "lastModified", "status"],
      "properties": {
        "name": { "type": "string" },
        "path": { "type": "string" },
        "variants": { "type": "array", "items": { "type": "string" } },
        "props": { "type": "object" },
        "usage": { "type": "string" },
        "dependencies": { "type": "array", "items": { "type": "string" } },
        "dateCreated": { "type": "string", "format": "date" },
        "lastModified": { "type": "string", "format": "date" },
        "status": { "enum": ["production", "beta", "deprecated"] }
      }
    }
  }
}
